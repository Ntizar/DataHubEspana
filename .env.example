# DataHub España — Variables de entorno
# Copia este archivo a .env y rellena con tus API keys

# ESIOS/REE — Token API (gratis en https://api.esios.ree.es/)
# Solo necesario para el proxy, NO se incluye en el frontend
ESIOS_API=tu_token_esios_aqui

# NAP DGT — API key (gratis en https://nap.dgt.es/)
NAP_API=tu_api_key_nap_aqui

# Opcional: URL del proxy ESIOS desplegado
# Si usas Cloudflare Worker: https://esios-proxy.tu-subdominio.workers.dev
# Si usas NaN: https://esios-proxy.apps.nan.builders
ESIOS_PROXY_URL=
